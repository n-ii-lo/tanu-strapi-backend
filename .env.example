HOST=0.0.0.0
PORT=1337

# Додаткові Origin для CORS (через кому), наприклад кастомний домен на Vercel:
# CORS_ORIGIN=https://www.example.com,https://example.com

# Якщо логін в адмінку на Strapi Cloud дає 500: Project → Logs (Runtime) під час POST /admin/login (stack trace).
# У production порожні APP_KEYS / ADMIN_JWT_SECRET / солі — інстанс не стартує (див. config/server.js).

# Генеруйте ці значення командою: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS="randomKey1,randomKey2"
API_TOKEN_SALT=randomSalt
ADMIN_JWT_SECRET=randomSecret
TRANSFER_TOKEN_SALT=randomSalt2
JWT_SECRET=randomJwtSecret

# База даних (SQLite для локальної розробки, Strapi Cloud використовує Postgres автоматично)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
